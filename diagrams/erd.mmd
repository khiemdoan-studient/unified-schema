    khiem_v_doom_loop_students {
        string student_id PK "Full student ID"
        string student_name "Student name"
        string campus_id FK "Campus ID"
        string subject PK "Subject"
        int knowledge_grade PK "Knowledge grade"
        string teacher_name "Teacher"
        date doom_loop_entry_date "Date entered doom loop"
