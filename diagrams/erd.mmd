        string campus_id FK "Campus ID"
        string campus_name "Campus name"
        string school_abbrev "Short campus name"
        string school_level "Elem, Middle, High"
        string grade "Grade"
        string teacher_name "Teacher"
        string teacher_email "Teacher email"
        string advisor_email "Advisor email"
        string student_group "Student group"
